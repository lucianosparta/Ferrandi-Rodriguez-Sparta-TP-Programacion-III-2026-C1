<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/images/favicon.ico" type="image/icon">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">
    <link rel="stylesheet" href="/css/producto-form-style.css">
    <script src="/js/theme.js"></script>
    <title>Formulario Producto - FRS Gaming</title>
</head>
<body class="d-flex flex-column min-vh-100">
    <!-- Navbar -->
    <nav class="navbar bg-body-tertiary shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/admin/dashboard">
                <img src="/images/icono.png" alt="Logo" width="30" height="30" class="d-inline-block align-text-top"/>
                <strong>FRS Gaming</strong>
            </a>

            <div class="d-flex align-items-center gap-2">
                <a class="btn btn-purple btn-sm" href="/admin/dashboard">Dashboard</a>
                <button type="button" class="btn btn-purple btn-sm" onclick="cambiarTema()">
                    <span class="material-symbols-outlined d-flex">invert_colors</span>
                </button>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow-1">
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div id="card" class="card-light border-purple p-4">
                        <div class="border-secondary pb-3 mb-4">
                            <p class="text-purple mb-1 small fw-semibold text-uppercase ls">FRS Gaming</p>
                            <% if (producto) { %>
                                <h1 id="formTitle" class="fs-7 fw-semibold mb-0">Editar Producto</h1>
                            <% } else { %>
                                <h1 id="formTitle" class="fs-7 fw-semibold mb-0">Agregar Nuevo Producto</h1>
                            <% } %>
                        </div>

                        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <strong>Errores encontrados:</strong>
                                <ul class="mb-0">
                                    <% errors.forEach(error => { %>
                                        <li><%= error %></li>
                                    <% }); %>
                                </ul>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        <% } %>

                        <% if (typeof exito !== 'undefined' && exito) { %>
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <%= exito %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        <% } %>

                        <form method="POST" action="<% if (producto) { %>/admin/producto/<%= producto.id %>/actualizar<% } else { %>/admin/producto/crear<% } %>" enctype="multipart/form-data">
                            <!-- Nombre -->
                            <div class="mb-3">
                                <label for="nombre" class="form-label">Nombre del Producto</label>
                                <input type="text" class="form-control" id="nombre" name="nombre" value="<% if (producto) { %><%= producto.nombre %><% } %>" required>
                            </div>

                            <!-- Descripción -->
                            <div class="mb-3">
                                <label for="descripcion" class="form-label">Descripción</label>
                                <textarea class="form-control" id="descripcion" name="descripcion" rows="3" required><% if (producto) { %><%= producto.descripcion %><% } %></textarea>
                            </div>

                            <!-- Categoría -->
                            <div class="mb-3">
                                <label for="categoria" class="form-label">Categoría</label>
                                <select class="form-select" id="categoria" name="categoria" required>
                                    <option value="">Seleccionar categoría</option>
                                    <option value="consolas" <% if (producto && producto.categoria === 'consolas') { %>selected<% } %>>Consolas</option>
                                    <option value="videojuegos" <% if (producto && producto.categoria === 'videojuegos') { %>selected<% } %>>Videojuegos</option>
                                </select>
                            </div>

                            <!-- Precio -->
                            <div class="mb-3">
                                <label for="precio" class="form-label">Precio ($)</label>
                                <input type="number" class="form-control" id="precio" name="precio" step="0.01" value="<% if (producto) { %><%= producto.precio %><% } %>" required>
                            </div>

                            <!-- Stock -->
                            <div class="mb-3">
                                <label for="stock" class="form-label">Stock</label>
                                <input type="number" class="form-control" id="stock" name="stock" value="<% if (producto) { %><%= producto.stock %><% } %>" required>
                            </div>

                            <!-- Imagen -->
                            <div class="mb-3">
                                <label for="imagen" class="form-label">Carga de imagen del Producto</label>
                                <input type="file" class="form-control" id="imagen" name="imagen" accept="image/*" <% if (!producto) { %>required<% } %>>
                                <small class="form-text text-secondary">Selecciona una imagen (ej: .jpg, .png)</small>
                                <% if (producto && producto.imagen) { %>
                                    <div class="mt-2">
                                        <small class="text-secondary">Imagen actual:</small>
                                        <div>
                                            <img src="/imagenes/productos/<%= producto.imagen %>" alt="<%= producto.nombre %>" style="max-width: 100px; max-height: 100px;">
                                        </div>
                                    </div>
                                <% } %>
                            </div>

                            <!-- Botones -->
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-purple fw-semibold" id="submitBtn">
                                    <% if (producto) { %>
                                        Guardar Cambios
                                    <% } else { %>
                                        Guardar Producto
                                    <% } %>
                                </button>
                                <a href="/admin/dashboard" class="btn btn-secondary fw-semibold">Cancelar</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-body-tertiary border-top py-4 text-center mt-5">
        <div>
            <p class="text-secondary small mb-0">
                Franco Ferrandi - Augusto Rodriguez - Luciano Sparta | Programación III - 2026
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
</body>
</html>

